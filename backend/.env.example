APP_NAME=python-backend-foundation
APP_ENV=development
APP_DEBUG=false
APP_LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8000
APP_CORS_ORIGINS=*
APP_WORKER_POLL_INTERVAL_SECONDS=1.0
APP_WORKER_BATCH_SIZE=5
APP_REQUEST_TIMEOUT_SECONDS=5
APP_DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/postgres
SIMULATION_STALE_RUN_TIMEOUT_SECONDS=1200
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1
LLM_PROVIDER=openai
LLM_REQUEST_TIMEOUT_MS=120000
LLM_MAX_TOKENS=4096
SUPABASE_URL=
SUPABASE_ANON_KEY=
