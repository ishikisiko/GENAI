LLM_PROVIDER=openai
LLM_API_KEY=your-llm-api-key
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1
LLM_MAX_TOKENS=4096

# Anthropic-compatible configuration. Useful for providers that expose an Anthropic-style API.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=
ANTHROPIC_VERSION=2023-06-01

# Backward-compatible fallback. Keep this only if you want to continue using the old name.
OPENAI_API_KEY=

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key-from-supabase-status
